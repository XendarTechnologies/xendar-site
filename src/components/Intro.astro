---

---

<section id="intro" class="relative z-10 -mt-px py-16 lg:py-24 bg-white overflow-hidden">
  <div class="intro-video-layer pointer-events-none absolute hidden lg:block z-0">
    <div
      class="intro-video-fade absolute inset-0"
      style="mask-image: linear-gradient(to left, #000 62%, transparent 100%), linear-gradient(to top, #000 76%, transparent 100%); -webkit-mask-image: linear-gradient(to left, #000 62%, transparent 100%), linear-gradient(to top, #000 76%, transparent 100%);"
    >
      <video
        class="h-full w-full object-contain opacity-72"
        style="object-position: right bottom;"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="/video-intro.mp4" type="video/mp4" />
      </video>
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative z-10 max-w-3xl text-center lg:text-left">
        <h2
          data-scroll-fill
          class="scroll-fill-title max-w-4xl mx-auto lg:mx-0 text-3xl sm:text-4xl lg:text-5xl font-bold text-center lg:text-left leading-tight"
        >
          <span class="scroll-fill-line">
            <span class="scroll-fill-word">Cada</span>
            <span class="scroll-fill-word">camión</span>
            <span class="scroll-fill-word">genera</span>
            <span class="scroll-fill-word">datos.</span>
          </span>
          <span class="scroll-fill-line">
            <span class="scroll-fill-word">Xendar</span>
            <span class="scroll-fill-word">los</span>
            <span class="scroll-fill-word">convierte</span>
            <span class="scroll-fill-word">en</span>
            <span class="scroll-fill-word">ahorro</span>
            <span class="scroll-fill-word">real.</span>
          </span>
        </h2>
        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Analizamos los viajes de tu flota para detectar: kilómetros en vacío, desvíos innecesarios,
          consumo de combustible y eficiencia de cada ruta.
          <br />
          Todo sin instalar hardware nuevo, a través de los datos GPS del celular del conductor y
          algoritmos avanzados.
        </p>

        <div class="mt-8 lg:hidden w-full max-w-md mx-auto">
          <video
            class="intro-mobile-video w-full h-auto object-contain opacity-72"
            style="object-position: center bottom;"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="/video-intro.mp4" type="video/mp4" />
          </video>
        </div>
    </div>

    <!-- Trusted By -->
    <div class="mt-16 max-w-3xl mx-auto lg:mx-0">
      <p class="text-center lg:text-left text-sm font-bold text-gray-500 tracking-wider mb-8">
        Diseñado para operaciones de carga pesada con foco en margen por kilómetro.
      </p>
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-12 gap-y-8 opacity-60">
        <div class="text-2xl font-bold text-gray-400">Flotas propias</div>
        <div class="text-2xl font-bold text-gray-400">Operadores regionales</div>
        <div class="text-2xl font-bold text-gray-400">PYMES en crecimiento</div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-video-layer {
    top: 0.7rem;
    bottom: 0.2rem;
    right: -120px;
    width: 1080px;
  }

  .intro-video-fade {
    mask-image: linear-gradient(to left, #000 62%, transparent 100%),
      linear-gradient(to top, #000 76%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, #000 62%, transparent 100%),
      linear-gradient(to top, #000 76%, transparent 100%);
  }

  .scroll-fill-line {
    display: block;
  }

  .scroll-fill-word {
    display: inline-block;
    margin-right: 0.22em;
    color: #9ca9b6;
    transition: color 180ms ease;
  }

  .scroll-fill-word.is-filled {
    color: var(--color-navy, #243b5a);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-fill-word {
      color: var(--color-navy, #243b5a) !important;
      transition: none;
    }
  }

	  @media (min-width: 1601px) {
    .intro-video-layer {
      right: -50px;
      width: 1240px;
    }
  }


	  @media (min-width: 1282px) and (max-width: 1600px) {
    .intro-video-layer {
      right: -200px;
      width: 1240px;
    }
  }

	  @media (min-width: 1201px) and (max-width: 1281px) {
    .intro-video-layer {
      right: -300px;
      width: 1240px;
    }
  }

  @media (min-width: 1151px) and (max-width: 1200px) {
    .intro-video-layer {
      right: -300px;
      width: 1240px;
    }
  }

  @media (min-width: 1024px) and (max-width: 1150px) {
    .intro-video-layer {
      right: -350px;
      width: 1240px;
    }
  }

  @media (max-width: 1023px) {
    .intro-mobile-video {
      transform: translateX(-35%);
      width: 130%;
      max-width: none;
    }
  }
</style>

<script>
  const title = document.querySelector('[data-scroll-fill]');

  if (title instanceof HTMLElement) {
    const words = Array.from(title.querySelectorAll('.scroll-fill-word'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (reduceMotion.matches) {
      words.forEach((word) => word.classList.add('is-filled'));
    } else {
      let ticking = false;

      const updateProgress = () => {
        ticking = false;
        const rect = title.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;

        const start = vh * 0.88;
        const end = vh * 0.28;
        const raw = (start - rect.top) / (start - end);
        const progress = Math.max(0, Math.min(1, raw));
        const activeWords = Math.floor(progress * words.length);

        words.forEach((word, index) => {
          word.classList.toggle('is-filled', index < activeWords);
        });
      };

      const requestUpdate = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        }
      };

      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);
      updateProgress();
    }
  }
</script>
