---

---

<section id="intro" class="relative z-10 py-16 lg:py-24 lg:h-200 bg-white overflow-hidden">
  <div class="intro-video-layer pointer-events-none absolute hidden lg:block z-0">
    <div class="intro-video-fade absolute inset-0">
      <video
        class="intro-video-el h-full w-full object-contain opacity-72"
        style="object-position: right bottom;"
        autoplay
        muted
        loop
        playsinline
        preload="none"
      >
        <source data-src="/video-intro.mp4" type="video/mp4" />
        <track kind="captions" src="/captions/video-intro.es.vtt" srclang="es" label="Español" />
      </video>
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="intro-text-content">
      <div class="intro-copy-panel relative z-10 max-w-3xl text-center lg:text-left">
        <h2 class="max-w-4xl mx-auto lg:mx-0 text-3xl sm:text-4xl lg:text-5xl font-bold text-center lg:text-left text-navy leading-tight">
          <span class="block">Cada camión genera datos.</span>
          <span class="block">Xendar los convierte en ahorro real.</span>
        </h2>
        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Analizamos los viajes de tu flota para detectar: kilómetros en vacío, desvíos innecesarios,
          consumo de combustible y eficiencia de cada ruta.
          <br />
          Todo sin instalar hardware nuevo, a través de los datos GPS del celular del conductor y
          algoritmos avanzados.
        </p>

        <div class="mt-8 lg:hidden w-full max-w-md mx-auto">
          <video
            class="intro-video-el intro-mobile-video w-full h-auto object-contain opacity-72"
            style="object-position: center bottom;"
            autoplay
            muted
            loop
            playsinline
            preload="none"
          >
            <source data-src="/video-intro.mp4" type="video/mp4" />
            <track kind="captions" src="/captions/video-intro.es.vtt" srclang="es" label="Español" />
          </video>
        </div>
      </div>

      <div class="mt-6 lg:mt-7 intro-segment-block w-full mx-auto lg:mx-0">
        <p class="intro-segment-title text-center lg:text-left text-base sm:text-lg font-semibold text-navy leading-tight">
          Diseñado para operaciones de carga pesada con foco en margen por kilómetro.
        </p>

        <div class="intro-segment-strip mt-6" role="list" aria-label="Segmentos">
          <div class="intro-segment-item" role="listitem">Flotas propias</div>
          <div class="intro-segment-item" role="listitem">Operadores regionales</div>
          <div class="intro-segment-item" role="listitem">PYMES en crecimiento</div>
        </div>

        <div class="intro-segment-carousel mt-6" aria-label="Segmentos móviles">
          <div class="intro-segment-track">
            <div class="intro-segment-chip">Flotas propias</div>
            <div class="intro-segment-chip">Operadores regionales</div>
            <div class="intro-segment-chip">PYMES en crecimiento</div>
            <div class="intro-segment-chip">Flotas propias</div>
            <div class="intro-segment-chip">Operadores regionales</div>
            <div class="intro-segment-chip">PYMES en crecimiento</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-video-layer {
    top: 0.7rem;
    bottom: 0.2rem;
    right: -120px;
    width: 1080px;
  }

  .intro-video-fade {
    mask-image: linear-gradient(to left, #000 62%, transparent 100%),
      linear-gradient(to bottom, #000 78%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, #000 62%, transparent 100%),
      linear-gradient(to bottom, #000 78%, transparent 100%);
  }

  .intro-segment-block {
    width: 100%;
    max-width: 760px;
  }

  .intro-segment-title {
    display: inline-block;
    width: 100%;
    padding: 0.35rem 0.2rem 0.55rem;
    border: 0;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .intro-segment-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid rgba(36, 59, 90, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.52);
    overflow: hidden;
    box-shadow: 0 8px 22px rgba(36, 59, 90, 0.06);
  }

  .intro-segment-item {
    min-height: 72px;
    display: grid;
    place-items: center;
    padding: 0 0.9rem;
    text-align: center;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.1;
    color: #243b5a;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .intro-segment-item + .intro-segment-item {
    border-left: 1px dashed rgba(36, 59, 90, 0.12);
  }

  .intro-segment-carousel {
    display: none;
    border: 1px solid rgba(36, 59, 90, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.52);
    overflow: hidden;
    box-shadow: 0 8px 22px rgba(36, 59, 90, 0.06);
  }

  .intro-segment-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 0.75rem;
    animation: intro-segment-marquee 14s linear infinite;
  }

  .intro-segment-chip {
    white-space: nowrap;
    font-size: 0.95rem;
    font-weight: 700;
    color: #243b5a;
    text-transform: none;
    padding: 0.48rem 0.86rem;
    border-radius: 999px;
    border: 1px solid rgba(36, 59, 90, 0.12);
    background: rgba(255, 255, 255, 0.72);
  }

  @media (min-width: 1024px) {
    .intro-segment-block {
      margin-inline: 0;
    }
  }

  @media (min-width: 1821px) {
    .intro-video-layer {
      right: -150px;
      width: 1320px;
    }
  }

  @media (min-width: 1681px) and (max-width: 1820px) {
    .intro-video-layer {
      right: -150px;
      width: 1320px;
    }
  }

  @media (min-width: 1501px) and (max-width: 1680px) {
    .intro-video-layer {
      right: -250px;
      width: 1320px;
    }
  }

  @media (min-width: 1351px) and (max-width: 1500px) {
    .intro-video-layer {
      right: -300px;
      width: 1280px;
    }
  }

  @media (min-width: 1281px) and (max-width: 1350px) {
    .intro-video-layer {
      right: -370px;
      width: 1250px;
    }
  }

  @media (min-width: 1201px) and (max-width: 1281px) {
    .intro-video-layer {
      right: -400px;
      width: 1220px;
    }
  }

  @media (min-width: 1151px) and (max-width: 1200px) {
    .intro-video-layer {
      right: -400px;
      width: 1180px;
    }
  }

  @media (min-width: 1024px) and (max-width: 1150px) {
    .intro-video-layer {
      right: -450px;
      width: 1180px;
    }

    .intro-video-fade {
      mask-image: linear-gradient(to left, #000 70%, transparent 100%),
        linear-gradient(to bottom, #000 70%, transparent 100%);
      -webkit-mask-image: linear-gradient(to left, #000 70%, transparent 100%),
        linear-gradient(to bottom, #000 70%, transparent 100%);
    }

    .intro-copy-panel {
      background: rgba(255, 255, 255, 0.56);
      border: 1px solid rgba(36, 59, 90, 0.14);
      border-radius: 1.05rem;
      box-shadow: 0 12px 30px rgba(36, 59, 90, 0.1);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      padding: 1.1rem 1.15rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1366px) {
    .intro-text-content {
      margin-top: 70px;
    }

    .intro-copy-panel {
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      padding: 0;
    }
  }

  @media (width: 1024px) and (height: 1366px) {
    .intro-video-layer {
      right: -500px;
    }
  }

  @media (max-width: 1023px) {
    .intro-copy-panel > .mt-8.lg\:hidden {
      margin-top: 0.5rem;
    }

    .intro-mobile-video {
      transform: translateX(-15%);
      width: 130%;
      max-width: none;
    }

    .intro-segment-strip {
      grid-template-columns: 1fr;
    }

    .intro-segment-item {
      min-height: 66px;
      font-size: 1.35rem;
    }

    .intro-segment-item + .intro-segment-item {
      border-left: 0;
      border-top: 1px dashed rgba(36, 59, 90, 0.12);
    }
  }

  @media (max-width: 767px) {
    .intro-segment-strip {
      display: none;
    }

    .intro-segment-carousel {
      display: block;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      overflow: visible;
    }

    .intro-segment-track {
      padding: 0.25rem 0;
      gap: 0.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-segment-track {
      animation: none;
    }
  }

  @keyframes intro-segment-marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  const setupIntroVideoPlayback = () => {
    const safeWindow = window as any;
    if (safeWindow.__introVideoReady) {
      return;
    }
    safeWindow.__introVideoReady = true;

    const videos = Array.from(document.querySelectorAll('.intro-video-el'));
    if (!videos.length) return;

    const hydrateAndPlay = (video: HTMLVideoElement) => {
      const source = video.querySelector('source[type="video/mp4"]');
      if (source instanceof HTMLSourceElement && !source.src && source.dataset.src) {
        source.src = source.dataset.src;
        video.load();
      }

      video.play().catch(() => {});
    };

    videos.forEach((video) => {
      if (!(video instanceof HTMLVideoElement)) return;
      video.muted = true;
      video.playsInline = true;
      video.loop = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');
      if (video.textTracks && video.textTracks.length) {
        Array.from(video.textTracks).forEach((track) => {
          track.mode = 'hidden';
        });
      }

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              hydrateAndPlay(video);
              observer.disconnect();
            });
          },
          { rootMargin: '120px 0px', threshold: 0.1 }
        );
        observer.observe(video);
      } else {
        hydrateAndPlay(video);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupIntroVideoPlayback, { once: true });
  } else {
    setupIntroVideoPlayback();
  }
</script>
