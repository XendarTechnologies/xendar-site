---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import Intro from '../components/Intro.astro';
import MapPanel from '../components/MapPanel.astro';
import Features from '../components/Features.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Xendar | Optimización logística para empresas de transporte de carga"
  description="Xendar optimiza operaciones de transporte de carga con inteligencia de datos: reduce costo por kilómetro, combustible, mantenimiento y kilómetros vacíos."
  canonical="https://xendar.com.ar"
  ogTitle="Xendar | Inteligencia logística para transporte de carga"
  ogDescription="Plataforma de optimización logística sin hardware para reducir costos y mejorar eficiencia operativa."
  twitterTitle="Xendar | Optimización logística basada en datos"
  twitterDescription="Menos kilómetros vacíos, mejor costo por kilómetro y control total de flota."
>
  <Navbar />
  <main>
    <Hero />
    <Intro />
    <MapPanel />
    <Features />
    <CTA />
  </main>
  <Footer />
</Layout>
