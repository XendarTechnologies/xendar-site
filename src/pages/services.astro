---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Servicios Xendar | Optimización logística sin hardware"
  description="Servicios de optimización logística para empresas de transporte: reducción de kilómetros vacíos, control de costos y eficiencia operativa."
  canonical="https://xendar.com.ar/services"
  ogTitle="Servicios Xendar | Eficiencia logística para transporte"
  ogDescription="Optimización logística sin hardware, foco en costo por kilómetro y arquitectura de datos privada por flota."
>
  <Navbar />
  <main class="pt-28 lg:pt-36 pb-16 lg:pb-24">
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-bold text-navy leading-tight">
        Servicios
      </h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        Plataforma de optimización logística para empresas y operadores profesionales.
      </p>

      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <article class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-navy">Eficiencia sin fricción</h2>
          <p class="mt-3 text-gray-600">
            Eliminamos la dependencia de hardware costoso. Nuestra inteligencia reside en el dato y el proceso.
          </p>
        </article>
        <article class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-navy">Foco en el margen</h2>
          <p class="mt-3 text-gray-600">
            No solo rastreamos camiones: optimizamos el costo por kilómetro para que cada viaje cuente.
          </p>
        </article>
        <article class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-navy">Arquitectura de confianza</h2>
          <p class="mt-3 text-gray-600">
            Entornos de datos CUE privados, seguros e inauditables por terceros.
          </p>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
