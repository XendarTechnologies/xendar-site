---
const features = [
  {
    icon: "location",
    title: "Operación continua, carga simple",
    description: "Requiere interacción mínima para cargar documentación: automatizamos el flujo de información sin exigir carga constante de datos.",
    stats: [
      { value: "100%", label: "Basado en datos" },
      { value: "0 HW", label: "Dependencia física" },
    ],
    color: "teal",
  },
  {
    icon: "status",
    title: "Foco en el costo por kilómetro",
    description: "Un algoritmo propio calcula los costos operativos para minimizar el gasto por kilómetro recorrido.",
    stats: [
      { value: "$/km", label: "Métrica central" },
      { value: "↓", label: "Kilómetros vacíos" },
    ],
    color: "blue",
  },
  {
    icon: "driver",
    title: "Arquitectura CUE privada",
    description: "Cada flota opera en un entorno de datos único, cifrado y segregado. La información queda protegida y no puede ser auditada por terceros.",
    stats: [
      { value: "1", label: "Entorno por cliente" },
      { value: "24/7", label: "Control operativo" },
    ],
    color: "cyan",
  },
];
---

<section id="features" class="py-16 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-teal/10 text-navy px-4 py-2 rounded-full text-sm font-semibold mb-6">
        Diferenciales Xendar
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-navy text-balance">
        Tecnología diseñada para mejorar la rentabilidad del transporte
      </h2>
      <p class="mt-6 text-lg text-gray-600">
        Combinamos experiencia en operaciones logísticas con desarrollo tecnológico para optimizar
        el costo por kilómetro y la eficiencia de cada uno de tus viajes.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <div
          class="feature-card feature-reveal group relative h-full flex flex-col bg-soft-white rounded-2xl p-8 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-gray-200"
          style={`--delay:${index * 180}ms;`}
        >
          <div class="feature-card-texture" aria-hidden="true"></div>
          <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-6 ${
            feature.color === "teal" ? "bg-teal/10" : feature.color === "blue" ? "bg-blue/10" : "bg-cyan/10"
          }`}>
            {feature.icon === "location" && (
              <svg class="w-7 h-7 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            )}
            {feature.icon === "status" && (
              <svg class="w-7 h-7 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            )}
            {feature.icon === "driver" && (
              <svg class="w-7 h-7 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            )}
          </div>

          <h3 class="text-xl font-bold text-navy mb-3">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed mb-6">{feature.description}</p>

          <div class="mt-auto flex gap-6 pt-6 border-t border-gray-200">
            {feature.stats.map((stat) => (
              <div>
                <div class={`text-xl font-bold ${
                  feature.color === "teal" ? "text-teal" : feature.color === "blue" ? "text-blue" : "text-cyan"
                }`}>{stat.value}</div>
                <div class="text-sm text-gray-600">{stat.label}</div>
              </div>
            ))}
          </div>

          <div class="absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-card {
    overflow: hidden;
    backdrop-filter: blur(2px);
  }

  .feature-card-texture {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(127, 198, 204, 0.14) 0%, rgba(127, 198, 204, 0) 60%),
      radial-gradient(90% 70% at 100% 100%, rgba(36, 59, 90, 0.08) 0%, rgba(36, 59, 90, 0) 65%),
      repeating-linear-gradient(
        -24deg,
        rgba(225, 230, 237, 0.2) 0px,
        rgba(225, 230, 237, 0.2) 1px,
        transparent 1px,
        transparent 16px
      );
    opacity: 0.8;
  }

  .feature-reveal {
    opacity: 1;
    transform: translateY(34px) scale(0.98);
    transition:
      opacity 900ms ease,
      transform 900ms ease;
    transition-delay: var(--delay, 0ms);
  }

  .feature-reveal.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const setupFeatureReveal = () => {
    const cards = Array.from(document.querySelectorAll(".feature-reveal"));
    if (!cards.length) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.matchMedia("(max-width: 1023px)").matches;
    const isFeaturesHash = window.location.hash === "#features";

    if (prefersReducedMotion || isMobile || isFeaturesHash || !("IntersectionObserver" in window)) {
      cards.forEach((card) => card.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
    );

    cards.forEach((card) => observer.observe(card));

    window.addEventListener("hashchange", () => {
      if (window.location.hash === "#features") {
        cards.forEach((card) => card.classList.add("is-visible"));
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupFeatureReveal, { once: true });
  } else {
    setupFeatureReveal();
  }
</script>
