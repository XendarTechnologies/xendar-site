---
const rawNumber = String(import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '');
const cleanNumber = rawNumber.replace(/\D/g, '');
const defaultMessage =
  'Hola Xendar, quiero conocer más sobre la plataforma y solicitar una demo.';
const message = String(import.meta.env.PUBLIC_WHATSAPP_MESSAGE ?? defaultMessage);
const href = cleanNumber
  ? `https://wa.me/${cleanNumber}?text=${encodeURIComponent(message)}`
  : '/#';
---

<a
  href={href}
  class="wa-float"
  aria-label="Escribir por WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <path
      fill="currentColor"
      d="M13.601 2.326A7.854 7.854 0 0 0 8.003.001C3.58.001 0 3.58 0 8.002c0 1.414.37 2.795 1.073 4.01L0 16l4.101-1.066a7.963 7.963 0 0 0 3.902 1.003h.001c4.423 0 8.002-3.58 8.002-8.002a7.95 7.95 0 0 0-2.405-5.609ZM8.004 14.6a6.58 6.58 0 0 1-3.357-.919l-.24-.144-2.438.634.651-2.378-.156-.245a6.588 6.588 0 0 1-1.007-3.546c0-3.64 2.962-6.603 6.604-6.603a6.56 6.56 0 0 1 4.675 1.94 6.56 6.56 0 0 1 1.933 4.672c-.001 3.64-2.963 6.603-6.606 6.603Zm3.615-4.932c-.197-.099-1.17-.577-1.352-.643-.18-.066-.312-.099-.443.099-.131.198-.508.643-.623.775-.115.132-.23.149-.426.05-.197-.099-.831-.306-1.583-.975-.585-.521-.98-1.164-1.095-1.362-.115-.198-.012-.305.087-.404.09-.09.197-.231.295-.347.098-.116.131-.198.196-.33.066-.132.033-.248-.016-.347-.05-.099-.443-1.066-.607-1.46-.16-.386-.323-.334-.443-.34h-.377c-.131 0-.344.05-.525.248-.18.198-.688.676-.688 1.65s.705 1.915.803 2.047c.098.132 1.39 2.123 3.368 2.978.47.203.837.324 1.124.415.472.15.902.129 1.241.078.379-.056 1.17-.478 1.336-.94.164-.463.164-.86.115-.94-.05-.082-.18-.132-.377-.23Z"
    />
  </svg>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 2147483000;
    width: 62px;
    height: 62px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #243b5a;
    color: #ffffff;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
    transition: transform 160ms ease, box-shadow 160ms ease;
    pointer-events: auto;
  }

  .wa-float:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.28);
  }

  .wa-float svg {
    width: 41px;
    height: 41px;
  }

  @media (max-width: 768px) {
    .wa-float {
      right: 14px;
      bottom: 14px;
      width: 56px;
      height: 56px;
    }

    .wa-float svg {
      width: 34px;
      height: 34px;
    }
  }
</style>
