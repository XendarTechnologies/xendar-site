---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contacto Xendar | Solicitá una demo"
  description="Contactá a Xendar para conocer la plataforma de optimización logística para transporte de carga en Argentina y Latinoamérica."
  canonical="https://xendar.com.ar/contact"
  ogTitle="Contacto Xendar | Solicitar demo"
  ogDescription="Hablemos de eficiencia logística, reducción de costos operativos y optimización de flotas."
  bodyClass="page-contact"
>
  <Navbar />
  <main class="pt-24 lg:pt-32 pb-14 lg:pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="contact-split rounded-3xl overflow-hidden border border-alice-blue/80 shadow-[0_18px_40px_rgba(36,59,90,0.08)]">
        <article class="contact-panel contact-panel-left p-8 sm:p-10 lg:p-14">
          <h1 class="text-4xl sm:text-5xl font-bold text-navy leading-tight">Contáctanos</h1>
          <p class="mt-6 text-xl text-ink-black font-semibold leading-snug max-w-xl">
            ¿Tenés dudas sobre Xendar? Escribinos y te respondemos para evaluar tu operación.
          </p>

          <ul class="mt-10 space-y-4 text-navy">
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-teal"></span>
              <span>Detectá en qué viajes se pierde margen operativo.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-teal"></span>
              <span>Implementación simple: sin hardware adicional.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-teal"></span>
              <span>Controlá documentación, eventos y trazabilidad en un solo flujo.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-teal"></span>
              <span>Soporte estratégico para operadores de carga pesada.</span>
            </li>
          </ul>

          <div class="mt-10 space-y-2 text-sm text-navy/85">
            <p><strong>Correo:</strong> contacto@xendar.com.ar</p>
            <p><strong>Teléfono:</strong> +54 3364 11 3181</p>
            <p><strong>Cobertura:</strong> Argentina y Latinoamérica</p>
          </div>
        </article>

        <article class="contact-panel bg-white p-8 sm:p-10 lg:p-14">
          <h2 class="text-3xl font-bold text-navy">Enviar mensaje</h2>

          <form id="contact-form" class="mt-8 space-y-6" action="/api/contact" method="post">
            <div>
              <label for="nombre" class="block text-sm font-semibold text-navy mb-2">Nombre</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                class="w-full rounded-xl border border-alice-blue bg-white px-4 py-3 text-navy outline-none transition focus:border-blue focus:ring-2 focus:ring-blue/15"
              />
            </div>

            <div>
              <label for="correo" class="block text-sm font-semibold text-navy mb-2">Correo electrónico</label>
              <input
                id="correo"
                name="correo"
                type="email"
                required
                class="w-full rounded-xl border border-alice-blue bg-white px-4 py-3 text-navy outline-none transition focus:border-blue focus:ring-2 focus:ring-blue/15"
              />
            </div>

            <div>
              <label for="empresa" class="block text-sm font-semibold text-navy mb-2">Empresa</label>
              <input
                id="empresa"
                name="empresa"
                type="text"
                class="w-full rounded-xl border border-alice-blue bg-white px-4 py-3 text-navy outline-none transition focus:border-blue focus:ring-2 focus:ring-blue/15"
              />
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-semibold text-navy mb-2">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                class="w-full resize-y rounded-xl border border-alice-blue bg-white px-4 py-3 text-navy outline-none transition focus:border-blue focus:ring-2 focus:ring-blue/15"
              ></textarea>
            </div>

            <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

            <button
              id="contact-submit"
              type="submit"
              class="w-full rounded-xl bg-blue py-3.5 font-semibold text-white transition hover:bg-blue-dark"
            >
              Enviar mensaje
            </button>

            <p id="contact-status" class="hidden text-sm font-medium" aria-live="polite"></p>
          </form>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-split {
    display: grid;
    grid-template-columns: 1fr;
    background: #ffffff;
  }

  .contact-panel {
    min-height: 540px;
  }

  .contact-panel-left {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background-color: #edf3f3;
    background-image:
      linear-gradient(125deg, rgba(237, 243, 243, 0.86) 0%, rgba(237, 243, 243, 0.78) 42%, rgba(237, 243, 243, 0.84) 100%),
      url('/Background2.png');
    background-size: cover, cover;
    background-position: center, center;
    background-repeat: no-repeat, no-repeat;
  }

  .contact-panel-left::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(237, 243, 243, 0.42);
    pointer-events: none;
  }

  .contact-panel-left > * {
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .contact-split {
      grid-template-columns: 1.04fr 0.96fr;
    }
  }
</style>

<script>
  const setupContactForm = () => {
    const form = document.getElementById('contact-form');
    const submitButton = document.getElementById('contact-submit');
    const status = document.getElementById('contact-status');

    if (!(form instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement) || !(status instanceof HTMLParagraphElement)) {
      return;
    }

    const resetStatus = () => {
      status.classList.add('hidden');
      status.classList.remove('text-red-600', 'text-teal');
      status.textContent = '';
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      resetStatus();

      submitButton.disabled = true;
      submitButton.classList.add('opacity-70', 'cursor-not-allowed');
      submitButton.textContent = 'Enviando...';

      try {
        const payload = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: payload,
          headers: {
            Accept: 'application/json',
          },
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          const errorMessage =
            typeof data?.detail === 'string' && data.detail.trim().length > 0
              ? data.detail
              : typeof data?.error === 'string' && data.error.trim().length > 0
                ? data.error
                : 'No se pudo enviar el mensaje.';
          throw new Error(errorMessage);
        }

        form.reset();
        status.textContent = 'Mensaje enviado. Te vamos a responder a la brevedad.';
        status.classList.remove('hidden');
        status.classList.add('text-teal');
      } catch (error) {
        const message = error instanceof Error
          ? error.message
          : typeof error === 'string'
            ? error
            : 'Error al enviar. Intentá nuevamente.';
        status.textContent = message;
        status.classList.remove('hidden');
        status.classList.add('text-red-600');
      } finally {
        submitButton.disabled = false;
        submitButton.classList.remove('opacity-70', 'cursor-not-allowed');
        submitButton.textContent = 'Enviar mensaje';
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupContactForm, { once: true });
  } else {
    setupContactForm();
  }

  document.addEventListener('astro:page-load', setupContactForm);
</script>
