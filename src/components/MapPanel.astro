---
const mapImageUrl = '/mapa-nocturno.png';
---

<section id="solutions" class="py-16 lg:py-24 bg-soft-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left - Map Visualization -->
      <div class="relative order-2 lg:order-1">
        <div class="relative bg-navy rounded-2xl overflow-hidden shadow-2xl">
          <!-- Map Header -->
          <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-teal/20 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
              </div>
              <span class="text-white font-medium">Vista de flota en vivo</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
              <span class="text-green-400 text-sm">Activo</span>
            </div>
          </div>

          <!-- Map Content -->
          <div class="h-[350px] lg:h-[420px]">
            <img
              src={mapImageUrl}
              class="w-full h-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Map Footer Stats -->
          <div class="px-6 py-4 bg-navy border-t border-white/10">
            <div class="grid grid-cols-3 gap-4">
              <div class="text-center">
                <div class="text-2xl font-bold text-cyan">24</div>
                <div class="text-xs text-gray-400">Vehículos activos</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-teal">18</div>
                <div class="text-xs text-gray-400">Entregas hoy</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-white">96%</div>
                <div class="text-xs text-gray-400">En horario</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating Card -->
        <div class="absolute -bottom-6 -right-6 bg-white rounded-xl shadow-xl p-4 w-56 hidden lg:block">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-navy">Entrega completada</div>
              <div class="text-xs text-gray-500 mt-1">Orden #4521 completada en centro de distribución</div>
              <div class="text-xs text-gray-400 mt-2">Hace 2 min</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right - Content -->
      <div class="order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 bg-blue/10 text-blue px-4 py-2 rounded-full text-sm font-medium mb-6">
          Monitoreo operativo
        </div>

        <h2
          data-scroll-fill-map
          class="scroll-fill-title text-3xl sm:text-4xl font-bold leading-tight"
        >
          <span class="scroll-fill-line">
            <span class="scroll-fill-word">Visibilidad</span>
            <span class="scroll-fill-word">completa</span>
            <span class="scroll-fill-word">de</span>
          </span>
          <span class="scroll-fill-line">
            <span class="scroll-fill-word">tu</span>
            <span class="scroll-fill-word">operación</span>
            <span class="scroll-fill-word">logística</span>
          </span>
        </h2>

        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Xendar permite a empresas y operadores detectar en tiempo real qué camiones están
          perdiendo dinero, dónde se generan kilómetros en vacío, qué rutas consumen más
          combustible y qué viajes tienen menor rentabilidad, entre otros indicadores.
        </p>

        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 bg-teal/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy">Telemetría en tiempo real</div>
              <div class="text-sm text-gray-500">Sin hardware costoso: inteligencia basada en datos y procesos.</div>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 bg-teal/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy">Gestión documental operativa</div>
              <div class="text-sm text-gray-500">Emití remitos, controlá seguros y recibí alertas de vencimiento.</div>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 bg-teal/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy">Notificaciones de eventos en ruta</div>
              <div class="text-sm text-gray-500">Alertas en tiempo real sobre desvíos, demoras y eventos críticos.</div>
            </div>
          </li>
        </ul>

        <a
          href="/services"
          class="inline-flex items-center gap-2 mt-8 text-blue font-semibold hover:underline"
        >
          Solicitá una prueba gratuita
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-fill-line {
    display: block;
  }

  .scroll-fill-word {
    display: inline-block;
    margin-right: 0.22em;
    color: #9ca9b6;
    transition: color 180ms ease;
  }

  .scroll-fill-word.is-filled {
    color: var(--color-navy, #243b5a);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-fill-word {
      color: var(--color-navy, #243b5a) !important;
      transition: none;
    }
  }
</style>

<script>
  const setupMapScrollFill = () => {
    const safeWindow = window as any;

    if (typeof safeWindow.__mapScrollFillCleanup === 'function') {
      safeWindow.__mapScrollFillCleanup();
    }

    const title = document.querySelector('[data-scroll-fill-map]');
    if (!(title instanceof HTMLElement)) {
      safeWindow.__mapScrollFillCleanup = null;
      return;
    }

    const words = Array.from(title.querySelectorAll('.scroll-fill-word'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (reduceMotion.matches) {
      words.forEach((word) => word.classList.add('is-filled'));
      safeWindow.__mapScrollFillCleanup = null;
      return;
    }

    let ticking = false;

    const updateProgress = () => {
      ticking = false;
      const rect = title.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;

      const start = vh * 0.88;
      const end = vh * 0.28;
      const raw = (start - rect.top) / (start - end);
      const progress = Math.max(0, Math.min(1, raw));
      const activeWords = Math.floor(progress * words.length);

      words.forEach((word, index) => {
        word.classList.toggle('is-filled', index < activeWords);
      });
    };

    const requestUpdate = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(updateProgress);
      }
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    updateProgress();

    safeWindow.__mapScrollFillCleanup = () => {
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', requestUpdate);
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupMapScrollFill, { once: true });
  } else {
    setupMapScrollFill();
  }

  document.addEventListener('astro:page-load', setupMapScrollFill);
</script>
