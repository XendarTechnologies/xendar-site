<section class="relative pt-28 lg:pt-36 pb-16 lg:pb-24 overflow-hidden">
  <div class="absolute inset-0 -z-10 hidden md:block">
    <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-cyan/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-teal/10 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_22%,rgba(127,198,204,0.22),transparent_44%),radial-gradient(circle_at_84%_26%,rgba(59,175,175,0.18),transparent_46%),linear-gradient(130deg,rgba(255,255,255,0.56)_0%,rgba(255,255,255,0.08)_48%,rgba(255,255,255,0)_78%)]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid items-center">
      <div class="max-w-xl rounded-2xl bg-white/38 border border-white/40 shadow-sm p-4 sm:p-0 sm:bg-transparent sm:border-0 sm:shadow-none">
        <div class="inline-flex items-center gap-2 bg-white/90 text-navy px-4 py-2 rounded-full text-sm font-semibold border border-navy/15 shadow-sm mb-6">
          <span class="w-2 h-2 bg-teal rounded-full animate-pulse"></span>
          El futuro del transporte de carga
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-navy leading-tight">
          <span class="block whitespace-nowrap">Nacido en la ruta.</span>
          <span class="block whitespace-nowrap">Potenciado por datos.</span>
        </h1>
        <p class="mt-3 text-base text-gray-700">
					Transformamos cada viaje en datos auditables, trazabilidad verificable, métricas para tomar decisiones.
        </p>

        <p class="mt-4 text-base text-gray-700 font-medium">
          La operación deja de depender de la intuición y pasa a basarse en información real.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-blue text-white px-6 py-3.5 rounded-xl font-semibold hover:bg-blue-dark transition-colors shadow-lg shadow-blue/25">
            Solicitar Demo
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="#intro" class="inline-flex items-center justify-center gap-2 bg-white text-navy px-6 py-3.5 rounded-xl font-semibold border border-gray-200 hover:border-gray-300 hover:bg-gray-100 transition-colors">
            Conocer más
          </a>
        </div>

        <div class="mt-10 sm:mt-12 grid grid-cols-3 lg:grid-cols-[1fr_1fr_1.35fr] rounded-xl lg:rounded-2xl bg-white/52 lg:bg-white/42 border border-navy/15 shadow-lg shadow-navy/10 px-2 sm:px-5 lg:px-7 py-3 sm:py-4 lg:py-5">
          <div class="text-center lg:text-left px-2 sm:px-3 lg:px-4 border-r border-navy/12">
            <div class="text-2xl lg:text-3xl font-bold tracking-tight text-navy">20+</div>
            <div class="mt-1 text-xs sm:text-sm text-gray-600 leading-tight whitespace-normal lg:whitespace-nowrap">Años de experiencia</div>
          </div>
          <div class="text-center lg:text-left px-2 sm:px-3 lg:px-4 border-r border-navy/12">
            <div class="text-2xl lg:text-3xl font-bold tracking-tight text-navy">$/km</div>
            <div class="mt-1 text-xs sm:text-sm text-gray-600 leading-tight whitespace-normal lg:whitespace-nowrap">Foco en margen</div>
          </div>
          <div class="text-center lg:text-left px-2 sm:px-3 lg:px-4">
            <div class="text-2xl lg:text-3xl font-bold tracking-tight text-navy">CUE</div>
            <div class="mt-1 text-xs sm:text-sm text-gray-600 leading-tight whitespace-normal lg:whitespace-nowrap">Datos privados por flota</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 md:h-40 bg-[linear-gradient(to_bottom,rgba(255,255,255,0)_0%,rgba(255,255,255,0.72)_68%,#ffffff_100%)]"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-[2px] bg-white"></div>
</section>
