---

<section id="demo" class="py-16 lg:py-24 bg-soft-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative bg-navy rounded-3xl overflow-hidden">
      <!-- Background Pattern -->
      <div class="absolute inset-0">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice">
          <defs>
            <pattern id="ctaGrid" width="60" height="60" patternUnits="userSpaceOnUse">
              <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#1a2030" stroke-width="1"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#ctaGrid)" />
          
          <!-- Decorative Elements -->
          <circle cx="100" cy="50" r="80" fill="#3BAFAF" fill-opacity="0.1"/>
          <circle cx="700" cy="350" r="100" fill="#203AAC" fill-opacity="0.15"/>
          <circle cx="650" cy="80" r="40" fill="#3EDFF3" fill-opacity="0.1"/>
        </svg>
      </div>

      <!-- Content -->
      <div class="relative px-8 py-16 lg:px-16 lg:py-20">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white text-balance">
            Convertimos la complejidad operativa en ahorro medible.
          </h2>
          <p class="mt-6 text-lg text-gray-300 max-w-2xl mx-auto">
            Modernizamos la logística para reducir costos, simplificar procesos y darte más control sobre
            tu operación. Menos fricción, más trazabilidad y decisiones más rápidas con impacto real.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
            <a 
              href="/contact" 
              class="inline-flex items-center justify-center gap-2 bg-cyan text-navy px-8 py-4 rounded-xl font-semibold hover:bg-cyan/90 transition-colors"
            >
              Agendar una Demo
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a 
              href="/contact" 
              class="inline-flex items-center justify-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-semibold hover:bg-white/20 transition-colors border border-white/20"
            >
              Contactar al equipo
            </a>
          </div>

          <!-- Trust Indicators -->
          <div class="mt-12 pt-8 border-t border-white/10">
            <div class="flex flex-wrap items-center justify-center gap-8 text-gray-200 text-sm">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Implementación por etapas</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Sin dependencia de hardware</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Soporte estratégico continuo</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
